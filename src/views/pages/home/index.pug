extends ../../layouts/base

include ../../components/media-list/media-list

block config
  - pageTitle = ''
  - page = ''
  - isHome = true

block navbar
  include ../../components/layout/navbar/navbar

block content

  include ../../components/bg-forest/bg-forest

      

  .container
    .max-w-5xl.mx-auto
      h1.mt-9.text-center.tracking-widest.font-bodoni.font-thin.pt-4(class="md:mt-12 md:pt-6") My Five
      .content-holder.my-8.relative.z-10(class="h-[85vh] md:py-6 md:mt-12 md:px-6")
          div.overflow-x-hidden.overflow-y-auto.h-full.relative.mt-2(class="px-8 md:px-12 md:mt-1").custom-scrollbar-1
            .sticker.sticker--shiba-cartoony-bitch
            .sticker.sticker--orrell-badboys
            .sticker.sticker--rainbow-dash-cutie-mark
            .sticker.sticker--vr-shiba-rock
            p.text-justify.leading-8.text-lg <strong>My top five songs, artists, and albums</strong>—each a piece of art that resonates deeply with me. They’ve shaped my journey, sparked nostalgia, and serve as the soundtrack to my life. I hope they offer a glimpse into my soul and maybe inspire or connect with you too.
              span.block.mt-4(class="lg:inline lg:mt-0 lg:pl-4") <span class="text-yellow-400 mr-1">▶</span> <span class="hidden md:inline ">Click</span><span class="md:hidden" aria-hidden>Tap</span> each item to open more.
            p.leading-.italic.mt-2.text-pallete-primary-5.text-justify(class="md:text-right lg:mt-4") I revel in these moments. It brings me pure joy x

            section.mt-10.text-center.mx-auto(class="md:max-w-lg")
              h3.text-2xl.tracking-widest.font-bodoni Songs
              +mediaList('songs', [
                { title: 'Sprawl II', artist: 'Hey Ocean!', videoId: 'jdK4yczg_uY' },
                { title: 'Good Girl', artist: 'The Living Tombstone', videoId: 'q1pjmN3RF3c' },
                { title: 'Stop Crying Your Heart Out', artist: 'Oasis', videoId: 'dhZUsNJ-LQU' },
                { title: 'Universe', artist: 'Metajoker', videoId: 'fNOchIIms5w' },
                { title: 'Long Live', artist: 'Taylor Swift', videoId: 'TFglkZVPBY0' },
              ])

            section.mt-10.text-center.max-w-md.mx-auto(class="md:max-w-lg")
              h3.text-2xl.tracking-widest.font-bodoni Artists
              +mediaList('artists', [
                { title: 'Hey Ocean!' },
                { title: 'Daniel Ingram' },
                { title: 'Crywank' },
                { title: 'Oasis' }
              ], 'media-list--artists')

            section.mt-10.text-center.max-w-md.mx-auto(class="md:max-w-lg")
              h3.text-2xl.tracking-widest.font-bodoni Albums
              +mediaList('albums', [
                { 
                  title: 'The War of the Worlds', 
                  artist: 'Jeff Wayne', 
                  spotifyLink: 'album/7ligZljXfUtcKPCotWul5g?si=aqHTIteMTJ-SoN2Ue7yLyQ'
                },
                { 
                  title: 'Ocean Eyes', 
                  artist: 'Owl City', 
                  spotifyLink: 'album/3vf65wfk1EEjVhy6BjENsS?si=65adaf4ed44e4c5e'
                },
                { 
                  title: 'Live Breath Build Believe', 
                  artist: 'The Skints', 
                  spotifyLink: 'album/11GbsdBi8fViqec6nhRz0j?si=8e004175a6cd47ff'
                },
                { 
                  title: 'Liberation', 
                  artist: 'Marcus Warner', 
                  spotifyLink: 'album/5aKOgMD30tp42cVORMc57h?si=RQDoJnkHT6uKlqdlKWtuHQ'
                },
                { 
                  title: 'All Killer, No Filler', 
                  artist: 'Sum 41', 
                  spotifyLink: 'album/2UCWsnmZEVg9HhnMeKTsim?si=665b616dce7f46d7'
                },
              ])
          

block footer
  include ../../components/layout/footer/footer
