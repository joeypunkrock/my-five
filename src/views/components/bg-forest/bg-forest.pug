.scene
    .ufoWrap
        .center
            .ufoInner
                #ufo
                    ul.blinkers
                        each i in [1, 2, 3, 4]
                            li
                    .dome
                    .antigrav
                        .rings
                            .inner
                            ul
                                each i in Array(64).fill()
                                    li
                    .thrust
                        ul
                            each i in [1, 2, 3, 4, 5, 6, 7, 8]
                                li
    .foreground
        ul.trees3
            each i in Array(16).fill()
                li
        ul.trees2
            each i in Array(16).fill()
                li
        ul.trees1
            each i in Array(16).fill()
                li
    .background
        .stars
            each i in Array(22).fill()
                li.small
            each i in Array(17).fill()
                li
